# Inference provider selection
# heuristic = current default fallback mode
# vision = use the OpenAI Responses vision integration and fall back to heuristic if unavailable
AI_INFERENCE_PROVIDER=heuristic
AI_INFERENCE_DEBUG=false

# Concrete real vision provider
AI_VISION_PROVIDER=openai
OPENAI_API_KEY=
AI_VISION_MODEL=gpt-4.1-mini

# Optional overrides
OPENAI_BASE_URL=https://api.openai.com/v1
AI_VISION_ENDPOINT=
AI_VISION_API_KEY=
AI_VISION_MAX_PHOTOS=8
